{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node", "config": { "includeFiles": ["lib/**", "models/**", "routes/**", "middleware/**"] } }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server.js" }
  ],
  "functions": {
    "server.js": {
      "maxDuration": 30
    }
  }
}
